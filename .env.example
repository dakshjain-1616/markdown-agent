# ── Markdown Agent Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in the values you need.
# All variables are OPTIONAL — the agent runs in mock mode without any keys.

# ── LLM Backend selection ─────────────────────────────────────────────────────

# Path to a local GGUF model file for llama-cpp-python backend.
# When set, this takes highest priority.
# Example: /models/mistral-7b-instruct.Q4_K_M.gguf
LLAMA_MODEL_PATH=

# Number of context tokens for llama-cpp-python (default: 4096)
LLAMA_N_CTX=4096

# Number of CPU threads for llama-cpp-python (default: 4)
LLAMA_N_THREADS=4

# Number of GPU layers to offload (0 = CPU only, -1 = all layers to GPU)
LLAMA_N_GPU_LAYERS=0

# Anthropic Claude API key (second priority if LLAMA_MODEL_PATH is not set)
ANTHROPIC_API_KEY=

# Claude model to use with Anthropic backend (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI API key (third priority)
OPENAI_API_KEY=

# OpenAI model to use (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# Custom OpenAI-compatible endpoint (e.g. Ollama, LM Studio, vLLM)
OPENAI_BASE_URL=

# ── Agent behaviour ───────────────────────────────────────────────────────────

# Force a specific backend: auto | mock | anthropic | openai | llama | dry-run
AGENT_BACKEND=auto

# Default file paths (relative to working directory)
AGENT_PLAN_FILE=plan.md
AGENT_MEMORY_FILE=memory.md
AGENT_OUTPUT_FILE=output.md

# Maximum tokens for LLM response (default: 2048)
AGENT_MAX_TOKENS=2048

# Watch mode polling interval in seconds (default: 2)
AGENT_WATCH_INTERVAL=2

# ── Retry & resilience ────────────────────────────────────────────────────────

# Number of retries on LLM API failure before giving up (default: 2)
AGENT_MAX_RETRIES=2

# Seconds to wait between retries (default: 1.0)
AGENT_RETRY_DELAY=1.0

# Fall back to mock output if all retries fail (default: false)
# Useful in CI / demo environments where you always want output
AGENT_FALLBACK_TO_MOCK=false

# ── Debug / development ───────────────────────────────────────────────────────

# Print the full LLM prompt to stdout before generating (default: false)
AGENT_VERBOSE_PROMPT=false
